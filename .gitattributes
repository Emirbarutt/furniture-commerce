# Normalize repository text files to LF.
* text=auto eol=lf

*.md text
*.yml text
*.yaml text
*.json text
*.js text
*.ts text
*.tsx text
*.css text
*.scss text
*.html text
*.sh text eol=lf
Dockerfile text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary

